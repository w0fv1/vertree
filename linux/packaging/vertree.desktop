[Desktop Entry]
Version=1.0
Type=Application
Name=Vertree
GenericName=Single File Version Manager
GenericName[zh_CN]=单文件版本管理工具
Comment=Back up, monitor, and inspect version history for standalone files
Comment[zh_CN]=用于单文件的备份、监控与版本历史查看
Exec=vertree %f
Icon=vertree
Terminal=false
StartupNotify=true
StartupWMClass=io.github.w0fv1.vertree
Categories=Utility;FileTools;GTK;
Keywords=backup;version;history;monitor;file;
Keywords[zh_CN]=备份;版本;历史;监控;文件;
SingleMainWindow=true
X-GNOME-UsesNotifications=true
